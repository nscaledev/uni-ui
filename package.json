{
	"name": "unikorn-ui",
	"version": "0.1.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/unikorn-cloud/ui"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:integration": "playwright test",
		"test:unit": "vitest",
		"openapi:identity": "openapi-generator-cli generate -g typescript-fetch --global-property skipFormModel=false -i https://raw.githubusercontent.com/unikorn-cloud/identity/main/pkg/openapi/server.spec.yaml -o src/lib/openapi/identity",
		"openapi:kubernetes": "openapi-generator-cli generate -g typescript-fetch -i https://raw.githubusercontent.com/unikorn-cloud/kubernetes/main/pkg/openapi/server.spec.yaml -o src/lib/openapi/kubernetes",
		"openapi:region": "openapi-generator-cli generate -g typescript-fetch -i https://raw.githubusercontent.com/unikorn-cloud/region/main/pkg/openapi/server.spec.yaml -o src/lib/openapi/region",
		"openapi:compute": "openapi-generator-cli generate -g typescript-fetch -i https://raw.githubusercontent.com/unikorn-cloud/compute/main/pkg/openapi/server.spec.yaml -o src/lib/openapi/compute"
	},
	"devDependencies": {
		"@playwright/test": "^1.56.1",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@types/crypto-js": "^4.2.2",
		"@types/eslint": "^8.56.0",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "20.11.20",
		"@typescript-eslint/eslint-plugin": "^8.11.0",
		"@typescript-eslint/parser": "^8.11.0",
		"autoprefixer": "10.4.17",
		"eslint": "^9.13.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.45.1",
		"js-yaml": "^4.1.1",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.2.6",
		"svelte": "^5.53.6",
		"svelte-check": "^4.0.0",
		"ts-node": "^10.9.2",
		"tslib": "^2.4.1",
		"tsx": "^4.21.0",
		"typescript": "^5.5.0",
		"vite": "^5.4.21",
		"vitest": "^1.6.1"
	},
	"type": "module",
	"dependencies": {
		"@floating-ui/dom": "^1.6.8",
		"@openapitools/openapi-generator-cli": "^2.31.1",
		"@opentelemetry/api": "^1.8.0",
		"@opentelemetry/core": "^1.22.0",
		"@opentelemetry/resources": "^1.22.0",
		"@opentelemetry/sdk-trace-base": "^1.22.0",
		"@opentelemetry/semantic-conventions": "^1.22.0",
		"@sveltejs/adapter-node": "^4.0.1",
		"bits-ui": "^2.18.0",
		"crypto-js": "^4.2.0",
		"jose": "^5.2.2",
		"pretty-bytes": "^7.1.0",
		"semver": "^7.6.0",
		"svelte-portal": "^2.2.1",
		"unique-names-generator": "^4.7.1",
		"uuid": "^14.0.0"
	}
}
